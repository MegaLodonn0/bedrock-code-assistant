{
  "aws": {
    "access_key_id": "YOUR_ACCESS_KEY_ID_HERE",
    "secret_access_key": "YOUR_SECRET_ACCESS_KEY_HERE",
    "region": "us-east-1"
  },
  "bedrock": {
    "default_model": "anthropic.claude-opus-4-5-20251101-v1:0",
    "max_tokens": 2048,
    "temperature": 0.7,
    "timeout": 30
  },
  "assistant": {
    "name": "Code Assistant",
    "version": "1.0.0",
    "prompt_timeout": 30,
    "max_context_items": 10
  }
}
